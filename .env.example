DATABASE_URL="postgresql://user:password@localhost:5432/remotelog"

# ── SSH credential encryption ────────────────────────────────────────────────
# Required when storing SSH passwords. Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
REMOTELOG_API_KEY_SECRET="generate-with: openssl rand -base64 32"

# ── SMTP (required when RESELLER_MODE=true for e-mail verification) ──────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true for port 465
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM="RemoteLog <noreply@remotelog.de>"

# ── Reseller / SaaS mode (optional) ─────────────────────────────────────────
# Remove or leave unset to run as a normal self-hosted instance.
# RESELLER_MODE=true

# PayPal Subscriptions (required when RESELLER_MODE=true)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox   # or: live

# Daily backup endpoint token (required when RESELLER_MODE=true)
# BACKUP_TOKEN="generate-with: openssl rand -base64 32"
# Coolify cron: GET https://your-app.com/api/v1/reseller/backup?token=$BACKUP_TOKEN
